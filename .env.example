# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=rental
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=rental_management
DATABASE_URL=postgresql://rental:CHANGE_ME_strong_random_password@db:5432/rental_management

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
SESSION_COOKIE_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
SETTINGS_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Caddy / Domain ──────────────────────────────────────────────────────────
DOMAIN=app.example.com

# ─── Seed defaults (only used during initial setup) ──────────────────────────
SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_password
ORG_ADMIN_PASSWORD=CHANGE_ME_strong_password
AGENT_PASSWORD=CHANGE_ME_strong_password

# ─── File uploads ────────────────────────────────────────────────────────────
# UPLOAD_DIR=/app/uploads   # defaults to ./uploads in project root

# ─── Optional: Error tracking ────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Optional: SMTP (configured via admin panel, but can bootstrap here) ─────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=noreply@example.com
